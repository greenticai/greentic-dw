{
  "version": "0.2",
  "id": "dw.incident.analysis",
  "display_name": "Incident Analysis Coordinator",
  "worker_version": "0.5.1",
  "capabilities": {
    "offers": [],
    "requires": [],
    "consumes": [],
    "profiles": []
  },
  "tenancy": {
    "tenant": "tenant-ops",
    "team_policy": {
      "optional": {
        "default_team": "ops",
        "allow_request_override": true
      }
    }
  },
  "locale": {
    "worker_default_locale": "en-US",
    "policy": "prefer_requested",
    "propagation": "propagate_to_delegates",
    "output": "match_requested"
  },
  "deep_agent": {
    "enabled": true,
    "planning_capability": "greentic.cap.planning.plan",
    "workspace_capability": "greentic.cap.workspace.artifacts",
    "delegation_capability": "greentic.cap.delegation.route",
    "reflection_capability": "greentic.cap.reflection.review",
    "context_capability": "greentic.cap.context.compose",
    "plan_step_kinds": [
      "delegate",
      "review"
    ],
    "reflection_policy_mandatory": true
  }
}
